{
  "name": "kerchunk",
  "version": "0.9.6",
  "private": true,
  "description": "A self-contained AllStarLink-style node for the desktop — link to nodes, conference audio, and talk with push-to-talk. Includes Web Transceiver guest mode.",
  "author": "W9MDM",
  "license": "MIT",
  "copyright": "Copyright © 2026 W9MDM",
  "homepage": "https://www.qrz.com/db/W9MDM",
  "main": "./dist/main/index.cjs",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -b tsconfig.json",
    "format": "prettier --write .",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && node scripts/dist.mjs",
    "dist:win": "electron-vite build && node scripts/dist.mjs --win",
    "dist:mac": "electron-vite build && node scripts/dist.mjs --mac",
    "dist:linux": "electron-vite build && node scripts/dist.mjs --linux"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.3.1",
    "@fortawesome/free-brands-svg-icons": "^7.3.1",
    "@fortawesome/free-solid-svg-icons": "^7.3.1",
    "@fortawesome/react-fontawesome": "^3.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.17.1",
    "@typescript-eslint/parser": "^8.17.1",
    "autoprefixer": "^10.4.20",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^3.0.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jimp": "^0.22.12",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.7.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "build": {
    "appId": "org.w9mdm.kerchunk",
    "productName": "Kerchunk",
    "copyright": "Copyright © 2026 W9MDM",
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "!dist/**/*.test.*",
      "!dist/**/*.map",
      "package.json",
      "LICENSE",
      "THIRD-PARTY-NOTICES.md"
    ],
    "extraResources": [
      "LICENSE",
      "THIRD-PARTY-NOTICES.md",
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "license": "LICENSE",
      "shortcutName": "Kerchunk"
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Network",
      "maintainer": "W9MDM"
    }
  }
}

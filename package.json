{
  "name": "kerchunk",
  "version": "0.2.0-alpha",
  "private": true,
  "description": "A native desktop client for AllStarLink-style node operation built with Electron and TypeScript.",
  "main": "./dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -b tsconfig.json",
    "format": "prettier --write ."
  },
  "dependencies": {
    "electron": "^35.0.0",
    "electron-log": "^5.4.4",
    "electron-vite": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.17.1",
    "@typescript-eslint/parser": "^8.17.1",
    "autoprefixer": "^10.4.20",
    "electron-builder": "^26.0.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.7.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"

{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "./dist/shared",
    "rootDir": "./src/shared"
  },
  "include": ["src/shared/**/*.ts"]
}
